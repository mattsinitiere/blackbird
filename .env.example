# ---- Supabase (database + login) ----
# Supabase project -> Settings -> API. Safe to expose (protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ---- AI Insights ----
# Pick ONE provider. Free: gemini, groq. Paid: openai, anthropic.
AI_PROVIDER=gemini

# Optional model override. Defaults if blank:
#   gemini   -> gemini-2.5-flash      (free)
#   groq     -> llama-3.3-70b-versatile (free)
#   openai   -> gpt-4o-mini           (paid)
#   anthropic-> claude-3-5-haiku-latest (paid)
AI_MODEL=

# Set the key for the ONE provider you chose. These are server-only secrets
# (no NEXT_PUBLIC_ prefix) so they are never exposed to the browser.
GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
